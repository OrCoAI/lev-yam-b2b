# .env.example — copy this to .env and fill in real values
# NEVER commit .env to git

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=

# Grow Payments
# The webhookKey Grow sends with every webhook POST — get from Grow support
GROW_WEBHOOK_KEY=
# Sandbox: sandbox.meshulam.co.il | Production: api.meshulam.co.il
GROW_ENV=production

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# Dynatrace
DYNATRACE_INGEST_URL=https://xxxx.live.dynatrace.com/api/v2/events/ingest
DYNATRACE_API_TOKEN=

# GoDaddy (for DNS reference only — manage via dashboard)
# levyam.com DNS managed at: https://dcc.godaddy.com
